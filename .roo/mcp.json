      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "BSAbUyFmqOWNzJLV9h4OtbLAjrnoiHj"
      }
    },
    "mcp-server-firecrawl": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@smithery/cli@latest",
        "run",
        "@mendableai/mcp-server-firecrawl",
"--key",
"fc-f9fc77cd579f43eca18d3e59ee698025",
        "--profile",
        "ratty-donkey-M4QHTb"
      ]
